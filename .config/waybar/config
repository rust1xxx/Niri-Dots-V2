{
    "layer": "top",
    "position": "top",
    "margin-top": 5,
    "margin-left": 10,
    "margin-right": 10,
    "height": 30,
    "spacing": 10,

    "modules-left": ["niri/workspaces", "custom/cava"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "temperature", "memory", "disk", "pulseaudio", "niri/language"],

    "niri/workspaces": {
        "format": "{index}"
    },

    "custom/cava": {
    	"exec": "cava -p ~/.config/cava/config_waybar | sed -u 's/;//g;s/0/ /g;s/1/▂/g;s/2/▃/g;s/3/▄/g;s/4/▅/g;s/5/▆/g;s/6/▇/g;s/7/█/g;s/8/█/g;s/9/█/g'",
    	"format": "<span color='#ff9d26'>{}</span>"
    },

    "clock": {
        "format": "<span color='#ff8c00'>{:%H:%M:%S}</span>",
        "interval": 1
    },

    "cpu": {
        "format": "cpu: <span color='#ff9d26'>{usage}%</span>",
        "interval": 2
    },

    "temperature": {
        "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        "format": "tem: <span color='#ff9d26'>{temperatureC}°</span>"
    },

    "memory": {
        "format": "ram: <span color='#ff9d26'>{percentage}%</span>",
        "interval": 5
    },

    "disk": {
        "format": "mem: <span color='#ff9d26'>{percentage_used}%</span>",
        "path": "/"
    },

    "niri/language": {
        "format": "lng: <span color='#ff9d26'>{short}</span>"
    },

    "pulseaudio": {
        "format": "vol: <span color='#ff9d26'>{volume}%</span>"
    }
}

